# --- Database (Supabase → Connect → ORMs → Prisma) -----------------
# NOTE: real values go in .env (gitignored) — never commit secrets here.
# If the DB password contains / # @ etc., URL-encode them (%2F %23 %40).
# Pooled connection (pgbouncer, port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session-mode connection (port 5432) — used by prisma db push / migrate
DIRECT_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# --- Auth (Supabase Auth, email + password) -------------------------
# Publishable values — safe to expose to the browser, but real ones still
# live in .env. Project settings → API keys.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
# Login used by scripts/study-smoke.ts and scripts/prod-smoke.ts
E2E_EMAIL=""
E2E_PASSWORD=""
# Service-role (secret) key — Project settings → API keys. SERVER-ONLY, bypasses
# RLS. Powers self-serve account deletion (auth.admin.deleteUser). Never expose.
SUPABASE_SERVICE_ROLE_KEY=""

# --- AI integrations (Azure = translation, Gemini = enrichment) -----
# Azure AI Translator F0 (2M chars/month recurring): https://portal.azure.com
AZURE_TRANSLATOR_KEY=""
AZURE_TRANSLATOR_ENDPOINT="https://api.cognitive.microsofttranslator.com"
AZURE_TRANSLATOR_REGION=""
# Gemini API Free: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Used when GEMINI_MODEL is overloaded or out of daily quota (503/429).
# flash-lite has a separate, higher free-tier limit. "" disables fallback.
GEMINI_FALLBACK_MODEL="gemini-2.5-flash-lite"

# Optional DeepL fallback (Developer tier = 1M chars LIFETIME, no reset)
DEEPL_API_KEY=""
DEEPL_API_BASE_URL="https://api-free.deepl.com/v2"
ENABLE_DEEPL_FALLBACK="false"
