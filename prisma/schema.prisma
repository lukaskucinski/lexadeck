generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Deck {
  id          String   @id @default(cuid())
  userId      String // Supabase Auth user uuid — cards/reviews scope through the deck
  name        String
  language    String   @default("es") // ISO 639-1
  description String?
  accentColor String? // semantic token name, e.g. "coral"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards    Card[]
  sessions Session[]

  @@index([userId])
}

model Card {
  id     String @id @default(cuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  // content
  term        String
  translation String?
  language    String  @default("es")

  // classification (string-backed enums in lib/types.ts)
  cardType String  @default("VOCAB") // VOCAB | GRAMMAR | EXPRESSION
  wordType String  @default("OTHER")
  gender   String? // MASCULINE | FEMININE | NEUTER | EITHER

  // enrichment
  notes       String?
  conjugation String?
  example     String? // example sentence in the target language
  exampleEn   String? // English gloss of the example
  emoji       String?
  imageUrl    String?
  audioUrl    String?
  details     Json? // AI detail layer: usagePattern, collocations[], etymology, wordFamily[], correction (see lib/cardDetails.ts)
  enrichedAt  DateTime?

  // FSRS scheduling state (mirrors ts-fsrs Card)
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Float     @default(0)
  scheduledDays Float     @default(0)
  learningSteps Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0 New | 1 Learning | 2 Review | 3 Relearning
  lastReview    DateTime?

  // manual mastery override: set => excluded from study sessions until cleared
  masteredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews Review[]

  @@index([deckId, due])
  @@index([deckId, wordType])
  @@index([due])
}

model Review {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  rating     Int // ts-fsrs Rating: 1 Again | 2 Hard | 3 Good | 4 Easy
  state      Int // card state when reviewed
  reviewedAt DateTime @default(now())

  stabilityAfter  Float
  difficultyAfter Float
  dueAfter        DateTime

  @@index([cardId, reviewedAt])
  @@index([reviewedAt])
}

model Session {
  id        String    @id @default(cuid())
  deckId    String?
  deck      Deck?     @relation(fields: [deckId], references: [id])
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  cardCount Int       @default(0)

  reviews Review[]
}
